#!/bin/bash

# Create service account if not already done
touch environment
grep -q OC_SERVICE_ACCOUNT_ID environment || echo "OC_SERVICE_ACCOUNT_ID=$(cat /proc/sys/kernel/random/uuid)" >> environment
grep -q OC_SERVICE_ACCOUNT_SECRET environment || echo "OC_SERVICE_ACCOUNT_SECRET=$(head -c 1024 /dev/urandom | tr -cd A-Za-z0-9 | head -c 32)" >> environment